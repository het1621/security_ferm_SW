# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Security Agency Management Software
# Copy this to .env and fill in actual values
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Email (Nodemailer) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ─── Decimal Precision ──────────────────────────────────────────────────────
DECIMAL_PRECISION=2

# ─── Payroll Configuration (Phase 2-4) ───────────────────────────────────────
# PF contribution rate (default: 0.12 = 12%)
PF_RATE=0.12
# PF employee contribution monthly cap in INR
PF_CAP=15000
# Employer PF Account split (8.33%)
PF_ACCOUNT_SPLIT=0.0833
# Employer EPS split (3.67%)
EPS_SPLIT=0.0367

# ─── Tax Configuration (Phase 3) ─────────────────────────────────────────────
# 'new' or 'old' — Indian income tax regime
TAX_REGIME=new
# Education cess rate (default: 0.04 = 4%)
EDUCATION_CESS=0.04

# ─── Gratuity Configuration (Phase 4) ────────────────────────────────────────
# Maximum gratuity amount in INR (as per current law)
GRATUITY_CAP=2000000
# Minimum years of service for gratuity eligibility
GRATUITY_MIN_YEARS=5

# ─── GST Configuration (Phase 5) ─────────────────────────────────────────────
# Default GST rate for security services (18%)
GST_RATE=18
# Organization GSTIN
ORG_GSTIN=your-gstin-here
# State code for CGST/SGST vs IGST determination
ORG_STATE_CODE=24

# ─── Professional Tax (Phase 3) ──────────────────────────────────────────────
# State for professional tax calculation
PT_STATE=Gujarat

# ─── Backup Configuration ───────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups
